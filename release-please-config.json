{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "bump-minor-pre-major": false,
      "bump-patch-for-minor-pre-major": false,
      "changelog-sections": [
        { "type": "feat", "section": "Features" },
        { "type": "feature", "section": "Features" },
        { "type": "fix", "section": "Bug Fixes" },
        { "type": "perf", "section": "Performance" },
        { "type": "chore", "section": "Miscellaneous" },
        { "type": "docs", "section": "Documentation" },
        { "type": "ci", "section": "CI/CD" },
        { "type": "test", "section": "Tests" },
        { "type": "refactor", "section": "Refactoring" },
        { "type": "adr", "section": "Architecture" }
      ]
    },
    "packages/franken-brain": {
      "release-type": "node",
      "component": "franken-brain"
    },
    "packages/franken-critique": {
      "release-type": "node",
      "component": "franken-critique"
    },
    "packages/franken-governor": {
      "release-type": "node",
      "component": "franken-governor"
    },
    "packages/franken-heartbeat": {
      "release-type": "node",
      "component": "franken-heartbeat"
    },
    "packages/franken-mcp": {
      "release-type": "node",
      "component": "franken-mcp"
    },
    "packages/franken-observer": {
      "release-type": "node",
      "component": "franken-observer"
    },
    "packages/franken-orchestrator": {
      "release-type": "node",
      "component": "franken-orchestrator"
    },
    "packages/franken-planner": {
      "release-type": "node",
      "component": "franken-planner"
    },
    "packages/franken-skills": {
      "release-type": "node",
      "component": "franken-skills"
    },
    "packages/franken-types": {
      "release-type": "node",
      "component": "franken-types"
    },
    "packages/frankenfirewall": {
      "release-type": "node",
      "component": "frankenfirewall"
    }
  }
}
