{
  "name": "franken-comms",
  "version": "0.1.0",
  "description": "External Communication Channels for Frankenbeast (Slack, Discord, Telegram, WhatsApp)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start:network": "npm run build && node dist/server/start-comms-server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/"
  },
  "keywords": [
    "frankenbeast",
    "communications",
    "slack",
    "discord",
    "telegram",
    "whatsapp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@franken/types": "*",
    "hono": "^4.12.5",
    "ws": "^8.18.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/ws": "^8.18.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
